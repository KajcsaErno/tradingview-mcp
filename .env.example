# ─────────────────────────────────────────────────────────────────────────────
# Binance API credentials for the trading module (src/core/binance.js).
#
# Copy this file to `.env` (which is gitignored) and fill in your real keys:
#     cp .env.example .env
#
# These keys sign REST calls to Binance and CAN PLACE REAL ORDERS. Keep `.env`
# out of version control. The TradingView/CDP side of this project does NOT use
# these — they are only for the separate `tv binance` / binance_* tools.
#
# Recommended Binance API-key permissions:
#   • Enable Reading
#   • Enable Futures            (for USD-M / COIN-M trading)
#   • Enable Spot & Margin Trading   (only if you use spot)
#   • Permits Universal Transfer     (only if you use `tv binance transfer`)
#   • Restrict access to trusted IPs (recommended)
#   • Do NOT enable withdrawals
# ─────────────────────────────────────────────────────────────────────────────

# ── Account 1 — primary (the unsuffixed keys; used by default, account "1") ──
BINANCE_API_KEY=your_primary_api_key_here
BINANCE_API_SECRET=your_primary_api_secret_here

# ── Account 2 — used with `--account 2` (CLI) / account:"2" (MCP) ──
# Enables multi-account trade mirroring (`tv binance mirror-order` / `mirror-bracket`).
BINANCE_API_KEY_2=your_second_api_key_here
BINANCE_API_SECRET_2=your_second_api_secret_here

# ── Account 3 — used with `--account 3` / account:"3" ──
# Add as many as you need following the BINANCE_API_KEY_<n> / BINANCE_API_SECRET_<n> pattern.
BINANCE_API_KEY_3=your_third_api_key_here
BINANCE_API_SECRET_3=your_third_api_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# Testnet switch (paper trading)
#
# Set BINANCE_TESTNET=1 to route EVERY market to its testnet host
# (testnet.binancefuture.com / testnet.binance.vision) — no need to pass a
# "-testnet" market on each call. Order previews report live_funds:false.
#
# Testnet uses its OWN API keys (mainnet keys do NOT work on testnet). Get them
# from https://testnet.binancefuture.com — set them with the BINANCE_TESTNET_API_*
# names below (the same _2 / _3 … suffix scheme selects accounts). When the switch
# is OFF these are ignored.
# ─────────────────────────────────────────────────────────────────────────────
# BINANCE_TESTNET=1
# BINANCE_TESTNET_API_KEY=your_testnet_api_key_here
# BINANCE_TESTNET_API_SECRET=your_testnet_api_secret_here
# BINANCE_TESTNET_API_KEY_2=your_second_testnet_api_key_here
# BINANCE_TESTNET_API_SECRET_2=your_second_testnet_api_secret_here

# ─────────────────────────────────────────────────────────────────────────────
# Paper-trading kill-switch (master safety override)
#
# Set PAPER_TRADING=true (or BINANCE_PAPER_TRADING=true) to force EVERY money-moving
# function into dry-run: it logs the full decision/preview but sends NOTHING —
# even when confirm:true is passed. This is the guard for running a bot/automation
# wired for live (confirm:true everywhere) without risking a real fill: watch the
# logged decisions for a few days, confirm the logic matches what you expect, then
# unset this to go live. Dry-run responses include "paper_trading": true.
#
# Different from BINANCE_TESTNET (which still PLACES orders, just on the testnet
# exchange): PAPER_TRADING places NOTHING anywhere. They can be combined.
# ─────────────────────────────────────────────────────────────────────────────
# PAPER_TRADING=true
