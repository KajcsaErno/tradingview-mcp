# ─────────────────────────────────────────────────────────────────────────────
# Binance API credentials for the trading module (src/core/binance.js).
#
# Copy this file to `.env` (which is gitignored) and fill in your real keys:
#     cp .env.example .env
#
# These keys sign REST calls to Binance and CAN PLACE REAL ORDERS. Keep `.env`
# out of version control. The TradingView/CDP side of this project does NOT use
# these — they are only for the separate `tv binance` / binance_* tools.
#
# Recommended Binance API-key permissions:
#   • Enable Reading
#   • Enable Futures            (for USD-M / COIN-M trading)
#   • Enable Spot & Margin Trading   (only if you use spot)
#   • Permits Universal Transfer     (only if you use `tv binance transfer`)
#   • Restrict access to trusted IPs (recommended)
#   • Do NOT enable withdrawals
# ─────────────────────────────────────────────────────────────────────────────

# ── Account 1 — primary (the unsuffixed keys; used by default, account "1") ──
BINANCE_API_KEY=your_primary_api_key_here
BINANCE_API_SECRET=your_primary_api_secret_here

# ── Account 2 — used with `--account 2` (CLI) / account:"2" (MCP) ──
# Enables multi-account trade mirroring (`tv binance mirror-order` / `mirror-bracket`).
BINANCE_API_KEY_2=your_second_api_key_here
BINANCE_API_SECRET_2=your_second_api_secret_here

# ── Account 3 — used with `--account 3` / account:"3" ──
# Add as many as you need following the BINANCE_API_KEY_<n> / BINANCE_API_SECRET_<n> pattern.
BINANCE_API_KEY_3=your_third_api_key_here
BINANCE_API_SECRET_3=your_third_api_secret_here
