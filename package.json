{
  "name": "tradingview-mcp",
  "version": "1.0.0",
  "description": "MCP bridge for TradingView Desktop via Chrome DevTools Protocol",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "tv": "src/cli/index.js"
  },
  "exports": {
    ".": "./src/server.js",
    "./core": "./src/core/index.js"
  },
  "files": [
    "src/",
    "scripts/",
    "skills/",
    "agents/",
    "README.md",
    "CLAUDE.md"
  ],
  "scripts": {
    "start": "node src/server.js",
    "tv": "node src/cli/index.js",
    "test": "node --test \"tests/*.test.js\"",
    "test:e2e": "node --test tests/e2e.live.js",
    "test:unit": "node --test \"tests/*.test.js\"",
    "test:cli": "node --test tests/cli.test.js",
    "test:binance": "node --test \"tests/binance-*.test.js\"",
    "test:sanitization": "node --test tests/sanitization.test.js",
    "test:replay": "node --test tests/replay.test.js",
    "test:core": "node --test tests/core_di.test.js",
    "test:all": "node --test \"tests/*.test.js\" tests/e2e.live.js",
    "test:verbose": "node --test --test-reporter=spec tests/e2e.live.js tests/pine_analyze.test.js",
    "test:count": "node --test --test-reporter=spec tests/e2e.live.js 2>&1 | tail -5",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chrome-remote-interface": "^0.33.2"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.6.0"
  }
}
